{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["es2021", "esnext"],
    "allowJs": true,
    "sourceMap": true,
    "strict": true,
    "outDir": "../build",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "module": "es2022",
    "moduleResolution": "bundler",
    "declaration": true,
    "composite": true
  },
  "include": ["./*.ts"],
  "exclude": ["./**/*.spec.ts"]
}
